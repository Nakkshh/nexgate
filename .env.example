# Copy this to .env and fill in your values

# ── NeonDB (production) ───────────────────────────────────────────
# Get this from neon.tech → your project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=jdbc:postgresql://YOUR_NEON_HOST/nexgate?sslmode=require
DATABASE_USERNAME=your_neon_user
DATABASE_PASSWORD=your_neon_password

# ── Local dev overrides (docker-compose fills these automatically) ─
# Uncomment to use local postgres instead of NeonDB
# DATABASE_URL=jdbc:postgresql://localhost:5432/nexgate
# DATABASE_USERNAME=nexgate
# DATABASE_PASSWORD=nexgate

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Services ──────────────────────────────────────────────────────
MOCK_BACKEND_URL=http://localhost:8081
